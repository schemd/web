{
	"name": "schemd-web",
	"version": "0.1.0",
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^26",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"lighthouse": "^13.4.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^3.0.0"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"ci": "bun install --frozen-lockfile",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest run --project server",
		"test:component": "vitest run --project client",
		"test:coverage": "vitest run --coverage",
		"test:docs": "bun scripts/compile-doc-examples.ts",
		"test:e2e": "playwright test",
		"test:a11y": "playwright test e2e/accessibility.e2e.ts",
		"check:links": "playwright test e2e/links.e2e.ts",
		"check:budget": "bun scripts/check-budgets.ts",
		"lighthouse": "bun scripts/lighthouse.ts",
		"test": "bun run test:unit && bun run test:component && bun run test:docs && bun run test:e2e"
	},
	"type": "module",
	"dependencies": {
		"@schemd/core": "^0.2.1"
	}
}
